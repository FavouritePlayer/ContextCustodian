# Shared identity — same string used for the Scalekit user id AND the
# Actian collection name. This single value is the isolation contract.
DEMO_USER_ID=demo-user-1

# Scalekit (fill in after the 0:35 connect spike)
# Get these at app.scalekit.com -> Dashboard -> Developers -> Settings -> API Credentials
SCALEKIT_CLIENT_ID=
SCALEKIT_CLIENT_SECRET=
SCALEKIT_ENV_URL=
# Dashboard -> AgentKit -> Connections -> Create Connection -> Google Drive / Google Docs.
# Use the exact Connection name shown there (Scalekit appends a random
# suffix, e.g. googledrive-9jPiHf7A, it's not just the bare slug).
# OAuth config for both: Access Type = Offline, Prompt Behavior = Consent
# (Offline gets a refresh token at all; Consent guarantees Google reissues
# one on every re-authorization instead of silently omitting it).
GOOGLEDRIVE_CONNECTION_NAME=googledrive
GOOGLEDOCS_CONNECTION_NAME=googledocs

# Actian VectorAI — localhost:6574 locally; vectorai:6574 on Render (private network)
VECTORAI_HOST=localhost:6574

# Trial/product key from your Actian account (format:
# XXXXX-XXXXX-XXXXX-XXXXX-XXXXX-XXXXX). Activated against the running
# container via scripts/activate_license.sh (a REST call to
# /licenses/add — same thing the Local UI's License Manager page does at
# http://localhost:6575/dashboard/license). Without it you're on the
# Community 5,000-total-vector cap, which fails writes silently ~30s after
# the cap is hit.
ACTIAN_PRODUCT_KEY=

# Embeddings — OpenAI text-embedding-3-small, dim=1536. If you switch to
# Voyage, update EMBED_DIM too (1024) and recreate the collection: dim is
# fixed at creation.
OPENAI_API_KEY=
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# LLM adjudication (injection / stale passes)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cache so /audit never depends on a live re-run during the demo
AUDIT_CACHE_PATH=cache/audit.json

# Google Drive folder IDs for live quarantine/collapse (POST /fix). Create once in Drive.
QUARANTINE_FOLDER_ID=
ARCHIVE_FOLDER_ID=
